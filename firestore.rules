rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.email in [
        'james@hiapply.co',
        'gary@hiapply.co',
        'chefyaya@kdscomfortfood.com'
      ];
    }

    match /testimonials/{docId} {
      allow read: if true;
      allow create: if request.resource.data.approved == false;
      allow update, delete: if isAdmin();
    }

    match /menuItems/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /packages/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
