rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public can read approved testimonials
    match /testimonials/{docId} {
      allow read: if true;
      allow create: if request.resource.data.approved == false;
      allow update, delete: if request.auth != null;
    }

    // Admin-only collections (public read, authenticated write)
    match /menuItems/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /gallery/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /packages/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Site settings (public read, authenticated write)
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
